# Brevo email service
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=PATIENCE AI
CONTACT_TO_EMAIL=hello@patience.ai

# Database and auth
DATABASE_URL=postgresql://user:password@host/db?sslmode=require
ADMIN_SESSION_SECRET=generate_a_long_random_secret
ADMIN_USERNAME=patience-admin
ADMIN_PASSWORD=generate_a_long_random_password

# AI chatbot
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Optional
SITE_URL=https://your-domain.com

# Copy this file to .env.local for development.
# Add the same variables in Render Environment settings.
